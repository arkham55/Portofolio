# Ensure platform-specific optional SWC/Turbopack binaries are always installed.
# Next.js ships its native Rust compiler as optionalDependencies for every
# supported OS/arch triple. If CI uses --omit=optional, those binaries are
# skipped and the build falls back to a slow JS transpiler or fails entirely.
#
# `package-lock=true` locks the dependency tree for reproducible CI installs.
package-lock=true
